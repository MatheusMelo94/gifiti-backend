# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gifiti?appName=Cluster0

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=

# Server port (default: 8080)
PORT=8080

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Resend Email API — get your key at https://resend.com
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=hello@ggifiti.com

# Google OAuth — get from Google Cloud Console > Credentials > OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Swagger UI — enable ONLY in dev/staging, never in production
SWAGGER_ENABLED=true

# Frontend base URL (used in email links)
APP_BASE_URL=http://localhost:5173

# Cookie settings
# Set to false ONLY for local HTTP development (defaults to true for production)
APP_COOKIE_SECURE=false
APP_COOKIE_SAME_SITE=Lax
APP_COOKIE_DOMAIN=

# Cloudflare R2 Storage — get from R2 dashboard > Manage API Tokens
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=gifiti-user-uploads
R2_PUBLIC_URL=https://pub-your-hash.r2.dev
