# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gifiti?appName=Cluster0

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=

# Server port (default: 8080)
PORT=8080

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (Gmail SMTP) — use an App Password, not your account password
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@gifiti.com

# Swagger UI — enable ONLY in dev/staging, never in production
SWAGGER_ENABLED=true

# Frontend base URL (used in email links)
APP_BASE_URL=http://localhost:5173

# Cookie settings
# Set to false ONLY for local HTTP development (defaults to true for production)
APP_COOKIE_SECURE=false
APP_COOKIE_SAME_SITE=Lax
APP_COOKIE_DOMAIN=
